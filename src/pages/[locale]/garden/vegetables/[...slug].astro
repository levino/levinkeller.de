---
import { getCollection } from 'astro:content'
import Layout from '@levino/shipyard-base/layouts/Page.astro'
import type { GetStaticPaths } from 'astro'
import { getISOWeek } from '@/tools/calendarWeeks'

export const getStaticPaths = (async () => {
  const vegs = await getCollection('vegetables')
  return vegs.map((entry) => ({
    params: { slug: entry.id, locale: 'de' },
    props: { entry },
  }))
}) satisfies GetStaticPaths

const { entry: veg } = Astro.props
const canonicalUrl = `${Astro.site}de/garden/vegetables/${veg.id}/`

const sowingLogs = await getCollection('sowingLog')
const plantingLogs = await getCollection('plantingLog')

interface YearRecord {
  sowings: Array<{ date: string; week: number; plannedPlantOutWeek?: number }>
  plantings: Array<{ date: string; week: number }>
}

const effectiveWeeksToPlantOut =
  veg.data.weeksToPlantOut ?? (!veg.data.directSow ? 6 : undefined)

// Collect sowing history
const byYear = new Map<number, YearRecord>()

for (const log of sowingLogs) {
  const year = Number(log.id)
  for (const entry of log.data.entries) {
    const entryId =
      typeof entry.vegetable === 'object' ? entry.vegetable.id : entry.vegetable
    if (entryId === veg.id) {
      const week = getISOWeek(new Date(entry.date))
      const rec = byYear.get(year) ?? { sowings: [], plantings: [] }
      rec.sowings.push({
        date: entry.date,
        week,
        plannedPlantOutWeek: effectiveWeeksToPlantOut
          ? week + effectiveWeeksToPlantOut
          : undefined,
      })
      byYear.set(year, rec)
    }
  }
}

// Collect planting history
for (const log of plantingLogs) {
  const year = Number(log.id)
  for (const entry of log.data.entries) {
    const entryId =
      typeof entry.vegetable === 'object' ? entry.vegetable.id : entry.vegetable
    if (entryId === veg.id) {
      const week = getISOWeek(new Date(entry.date))
      const rec = byYear.get(year) ?? { sowings: [], plantings: [] }
      rec.plantings.push({ date: entry.date, week })
      byYear.set(year, rec)
    }
  }
}

const years = [...byYear.keys()].sort((a, b) => b - a)
---

<Layout canonicalUrl={canonicalUrl} title={veg.data.name}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="mb-6 text-2xl font-bold">{veg.data.name}</h1>

    {/* History */}
    {years.length > 0 && (
      <div class="mb-8">
        <h2 class="mb-3 text-lg font-semibold">Aussaaten & Pflanzungen</h2>
        <div class="space-y-3">
          {years.map((year) => {
            const { sowings, plantings } = byYear.get(year)!
            return (
              <div class="rounded-lg border border-base-300 bg-base-100 p-3">
                <span class="badge badge-neutral mr-2">{year}</span>
                <div class="mt-2 flex flex-wrap gap-2">
                  {sowings.map((s, i) => {
                    const planting = plantings[i]
                    return (
                      <>
                        <span class="badge badge-success badge-sm">
                          {sowings.length > 1 ? `${i + 1}. ` : ''}Gesät KW {s.week} ({s.date})
                        </span>
                        {planting ? (
                          <span class="badge badge-primary badge-sm">
                            Gepflanzt KW {planting.week} ({planting.date})
                          </span>
                        ) : s.plannedPlantOutWeek ? (
                          <span class="badge badge-info badge-sm badge-outline">
                            Pflanzen KW {s.plannedPlantOutWeek} (ausstehend)
                          </span>
                        ) : null}
                      </>
                    )
                  })}
                </div>
              </div>
            )
          })}
        </div>
      </div>
    )}

    <h2 class="mb-3 text-lg font-semibold">Aussaatfenster</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Von (KW)</th>
          <th>Bis (KW)</th>
          <th>Folgesaat</th>
          <th>Hinweise</th>
        </tr>
      </thead>
      <tbody>
        {
          veg.data.sowingWindows.map((w) => (
            <tr>
              <td>{w.from}</td>
              <td>{w.until}</td>
              <td>
                {w.successionIntervalWeeks
                  ? `alle ${w.successionIntervalWeeks} Wochen`
                  : '–'}
              </td>
              <td class="flex flex-wrap gap-1">
                {(w.underCover ?? false) && (
                  <span class="badge badge-sm badge-info">geschützt</span>
                )}
                {(w.overwintering ?? false) && (
                  <span class="badge badge-sm badge-warning">Überwinterung</span>
                )}
                {w.note && (
                  <span class="badge badge-sm badge-ghost">{w.note}</span>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>

    {(veg.data.rowSpacingCm || veg.data.plantSpacingCm) && (
      <div class="mt-6">
        <h2 class="mb-3 text-lg font-semibold">Abstände</h2>
        <div class="flex gap-4 text-sm">
          {veg.data.rowSpacingCm && (
            <span>Reihenabstand: <strong>{veg.data.rowSpacingCm} cm</strong></span>
          )}
          {veg.data.plantSpacingCm && (
            <span>Pflanzabstand: <strong>{veg.data.plantSpacingCm} cm</strong></span>
          )}
        </div>
      </div>
    )}

    <div class="mt-6">
      <a href="../sowing-calendar" class="btn btn-outline btn-sm">
        ← Zurück zum Aussaatkalender
      </a>
    </div>
  </div>
</Layout>
