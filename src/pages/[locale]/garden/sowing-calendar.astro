---
import { getCollection } from 'astro:content'
import { MONTHS_DE } from '@levino/shipyard-base'
import Layout from '@levino/shipyard-base/layouts/Page.astro'
import type { GetStaticPaths } from 'astro'
import {
  buildTrackedCalendar,
  getISOWeek,
  type PlantingLogEntry,
  type SowingCalendarEntry,
  type SowingLogEntry,
} from '@/tools/calendarWeeks'

export const getStaticPaths = (() => {
  return [
    {
      params: {
        locale: 'de',
      },
    },
  ]
}) satisfies GetStaticPaths

const year = 2026
const currentWeek = getISOWeek(new Date())

const vegetables = (await getCollection('vegetables')).filter(
  (v) => !v.data.skip
)

// Filter to current year for calendar display
const sowingEntries: SowingLogEntry[] = (await getCollection('sowingLog'))
  .filter((e) => e.data.date.startsWith(String(year)))
  .map((e) => ({
    id: e.id,
    vegetable:
      typeof e.data.vegetable === 'object'
        ? e.data.vegetable.id
        : e.data.vegetable,
    date: e.data.date,
  }))

const plantingEntries: PlantingLogEntry[] = (await getCollection('plantingLog'))
  .filter((e) => e.data.date.startsWith(String(year)))
  .map((e) => ({
    id: e.id,
    vegetable:
      typeof e.data.vegetable === 'object'
        ? e.data.vegetable.id
        : e.data.vegetable,
    date: e.data.date,
    sowingId:
      typeof e.data.sowing === 'object' ? e.data.sowing.id : e.data.sowing,
  }))

const { weekMap: calendarWeekMap, missedVegetables } = buildTrackedCalendar(
  vegetables,
  sowingEntries,
  plantingEntries,
  currentWeek
)

const sortedWeeks = [...calendarWeekMap.keys()].sort((a, b) => a - b)

// Map KW to approximate month name for grouping headers
const kwToMonth = (kw: number): string => {
  const date = new Date(year, 0, 1 + (kw - 1) * 7)
  return MONTHS_DE[date.getMonth()]
}

// Sort entries: urgent first, then alphabetically within each group
const sortByUrgency = (entries: SowingCalendarEntry[]) => {
  return [...entries].sort((a, b) => {
    // Done entries always last
    if (a.status === 'done' && b.status !== 'done') return 1
    if (a.status !== 'done' && b.status === 'done') return -1
    if (a.status === 'done' && b.status === 'done')
      return a.name.localeCompare(b.name)
    // Urgent (remaining <= 1) before non-urgent
    const urgentA = a.lastPossibleWeek - currentWeek <= 1
    const urgentB = b.lastPossibleWeek - currentWeek <= 1
    if (urgentA && !urgentB) return -1
    if (!urgentA && urgentB) return 1
    // Within same urgency group, sort alphabetically
    return a.name.localeCompare(b.name)
  })
}

// Urgency color: warm amber = last chance, soft sage = plenty of time
const urgencyColor = (entry: SowingCalendarEntry): string => {
  if (entry.status === 'done') return ''
  const remaining = entry.lastPossibleWeek - currentWeek
  if (remaining <= 1) return 'border-l-4 border-warning bg-warning/10'
  if (remaining <= 4) return 'border-l-4 border-secondary bg-secondary/10'
  return 'border-l-4 border-base-300 bg-base-200/50'
}

const spacingLabel = (entry: SowingCalendarEntry): string | undefined => {
  if (entry.plantSpacingCm && entry.rowSpacingCm) {
    return `${entry.rowSpacingCm} × ${entry.plantSpacingCm} cm`
  }
  if (entry.plantSpacingCm) return `${entry.plantSpacingCm} cm`
  return undefined
}

// Split weeks into current, past, and future
const currentWeekEntries = calendarWeekMap.get(currentWeek)
const pastWeeks = sortedWeeks.filter((kw) => kw < currentWeek)
const futureWeeks = sortedWeeks.filter((kw) => kw > currentWeek)
---

<Layout>
  {/* ── Print-only compact checklist ── */}
  <div class="print-checklist hidden print:block mx-auto max-w-4xl px-4 text-black">
    <h1 class="text-base font-bold mb-1">
      Aussaat KW {currentWeek}
    </h1>

    {currentWeekEntries && (() => {
      const sowingEntries = currentWeekEntries.filter((e) => e.type === 'sowing')
      const plantOutEntries = currentWeekEntries.filter((e) => e.type === 'plantOut')
      const todo = sortByUrgency(sowingEntries).filter((e) => e.status !== 'done')
      const urgent = todo.filter((e) => e.lastPossibleWeek - currentWeek <= 1)
      const normal = todo.filter((e) => e.lastPossibleWeek - currentWeek > 1)
      const urgentPots = urgent.filter((e) => !e.directSow)
      const urgentDirect = urgent.filter((e) => e.directSow)
      const normalPots = normal.filter((e) => !e.directSow)
      const normalDirect = normal.filter((e) => e.directSow)

      const renderItems = (entries: typeof todo, isUrgent: boolean, showSpacing = false) => (
        <div class="print-grid">
          {entries.map((entry) => (
            <label class:list={['print-item', isUrgent && 'print-item-urgent']}>
              <input type="checkbox" class:list={['print-checkbox', isUrgent && 'print-checkbox-urgent']} />
              <span class="print-name">{entry.name}</span>
              {entry.succession > 1 && <span class="print-note"> ({entry.succession}. Aussaat)</span>}
              {entry.note && <span class="print-note"> [{entry.note}]</span>}
              {entry.seedsPerCell && entry.seedsPerCell > 1 && <span class="print-note"> {entry.seedsPerCell}×/Topf</span>}
              {showSpacing && spacingLabel(entry) && <span class="print-note"> {spacingLabel(entry)}</span>}
            </label>
          ))}
        </div>
      )

      const renderPlantItems = (entries: SowingCalendarEntry[]) => (
        <div class="print-grid">
          {entries.map((entry) => (
            <label class="print-item">
              <input type="checkbox" class="print-checkbox" />
              <span class="print-name">{entry.name}</span>
              {entry.succession > 1 && <span class="print-note"> ({entry.succession}. Pflanzung)</span>}
              {spacingLabel(entry) && <span class="print-note"> {spacingLabel(entry)}</span>}
            </label>
          ))}
        </div>
      )

      return (todo.length > 0 || plantOutEntries.length > 0) && (
        <>
          {urgentPots.length > 0 && (
            <div class="print-section">
              <p class="print-section-title print-section-title-urgent">⚑ Letzte Chance – Vorkultur (Töpfe)</p>
              {renderItems(urgentPots, true)}
            </div>
          )}
          {urgentDirect.length > 0 && (
            <div class="print-section">
              <p class="print-section-title print-section-title-urgent">⚑ Letzte Chance – Direktsaat</p>
              {renderItems(urgentDirect, true, true)}
            </div>
          )}
          {normalPots.length > 0 && (
            <div class="print-section">
              <p class="print-section-title">Vorkultur (Töpfe)</p>
              {renderItems(normalPots, false)}
            </div>
          )}
          {normalDirect.length > 0 && (
            <div class="print-section">
              <p class="print-section-title">Direktsaat</p>
              {renderItems(normalDirect, false, true)}
            </div>
          )}
          {plantOutEntries.length > 0 && (
            <div class="print-section">
              <p class="print-section-title">Pflanzen</p>
              {renderPlantItems(plantOutEntries)}
            </div>
          )}
        </>
      )
    })()}
  </div>

  {/* ── Screen-only interactive view ── */}
  <div class="container mx-auto max-w-4xl px-4 print:hidden">
    <h1 class="m-4 text-center text-2xl font-bold">
      Aussaatkalender {year}
    </h1>
    <p class="mb-2 text-center text-sm opacity-70">
      Wochenweise Übersicht — aktuelle KW: {currentWeek}
    </p>
    <div class="mb-6 flex flex-wrap justify-center gap-3 text-xs">
      <span class="flex items-center gap-1">
        <span class="inline-block h-3 w-3 rounded-full bg-success"></span> Erledigt
      </span>
      <span class="flex items-center gap-1">
        <span class="inline-block h-3 w-6 border-l-4 border-warning bg-warning/10"></span> Letzte
        Chance
      </span>
      <span class="flex items-center gap-1">
        <span class="inline-block h-3 w-6 border-l-4 border-base-300 bg-base-200/50"></span> Noch
        Zeit
      </span>
    </div>

    {missedVegetables.length > 0 && (
      <div class="mb-6 rounded-lg bg-base-200 p-4">
        <h2 class="mb-2 text-sm font-medium opacity-70">
          Dieses Jahr nicht ausgesät
        </h2>
        <div class="flex flex-wrap gap-2">
          {missedVegetables.map((veg) => (
            <a
              href={`./vegetables/${veg.id}`}
              class="badge badge-outline badge-sm opacity-60 hover:opacity-100"
            >
              {veg.name}
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Current week — always visible and expanded */}
    {currentWeekEntries && (
      <div class="mb-6">
        <h2 class="mb-3 text-lg font-semibold">
          Diese Woche (KW {currentWeek})
        </h2>
        <ul class="list-none space-y-1">
          {sortByUrgency(currentWeekEntries).map((entry) => (
            <li
              class:list={[
                'rounded px-3 py-2',
                entry.status === 'done' ? 'bg-success/10' : urgencyColor(entry),
              ]}
            >
              <div class="flex items-center gap-2">
                {entry.status === 'done' && (
                  <span class="flex-shrink-0 text-success" title="Erledigt">&#10003;</span>
                )}
                <a
                  href={`./vegetables/${entry.id}`}
                  class:list={[
                    'link link-hover flex-shrink-0 font-medium',
                    entry.status === 'done' && 'line-through opacity-60',
                  ]}
                >
                  {entry.name}
                </a>
                {entry.status === 'done' && entry.actualDate && (
                  <span class="text-xs opacity-50">
                    ({entry.type === 'plantOut' ? 'gepflanzt' : 'gesät'} {entry.actualDate}, KW {entry.actualWeek})
                  </span>
                )}
                {entry.status !== 'done' && entry.type !== 'plantOut' && entry.lastPossibleWeek - currentWeek < 2 && (
                  <span class="text-xs font-medium text-warning">Letzte Chance</span>
                )}
                {entry.status !== 'done' && entry.type === 'sowing' && entry.lastPossibleWeek - currentWeek > 1 && (
                  <span class="text-xs opacity-50">(noch bis KW {entry.lastPossibleWeek})</span>
                )}
              </div>
              <div class="mt-1 ml-0 flex flex-wrap gap-1">
                {entry.type === 'plantOut' && (
                  <span class="badge badge-sm badge-primary">Pflanzen</span>
                )}
                {entry.succession > 1 && (
                  <span class="badge badge-sm badge-outline">
                    {entry.type === 'plantOut' ? `${entry.succession}. Pflanzung` : `${entry.succession}. Aussaat`}
                  </span>
                )}
                {entry.type === 'sowing' && entry.directSow && (
                  <span class="badge badge-sm badge-accent">Direktsaat</span>
                )}
                {entry.underCover && (
                  <span class="badge badge-sm badge-info">geschützt</span>
                )}
                {entry.overwintering && (
                  <span class="badge badge-sm badge-warning">Überwinterung</span>
                )}
                {entry.note && (
                  <span class="badge badge-sm badge-ghost">{entry.note}</span>
                )}
                {entry.seedsPerCell && entry.seedsPerCell > 1 && (
                  <span class="badge badge-sm badge-ghost">{entry.seedsPerCell}×/Topf</span>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* Past weeks — collapsed */}
    {pastWeeks.length > 0 && (
      <details class="mb-4">
        <summary class="cursor-pointer text-sm font-medium opacity-60 hover:opacity-100">
          Vergangene Wochen anzeigen ({pastWeeks.length})
        </summary>
        <div class="mt-2 space-y-1">
          {pastWeeks.map((kw, idx) => {
            const entries = calendarWeekMap.get(kw)!
            const month = kwToMonth(kw)
            const prevMonth = idx > 0 ? kwToMonth(pastWeeks[idx - 1]) : ''
            const showMonthHeader = month !== prevMonth
            return (
              <>
                {showMonthHeader && (
                  <div class="mt-4 mb-2 border-b pb-1">
                    <h3 class="text-base font-semibold opacity-70">{month}</h3>
                  </div>
                )}
                <div class="collapse collapse-arrow bg-base-200">
                  <input type="checkbox" />
                  <div class="collapse-title font-medium text-sm">
                    KW {kw}
                    <span class="ml-2 text-sm opacity-60">
                      ({entries.length} Einträge)
                    </span>
                  </div>
                  <div class="collapse-content">
                    <ul class="list-none space-y-1">
                      {entries.map((entry) => (
                        <li class="flex items-center gap-2 rounded px-2 py-1 bg-success/10">
                          <span class="text-success" title="Erledigt">&#10003;</span>
                          <a
                            href={`./vegetables/${entry.id}`}
                            class="link link-hover line-through opacity-60"
                          >
                            {entry.name}
                          </a>
                          {entry.type === 'plantOut' && (
                            <span class="badge badge-sm badge-primary opacity-60">Pflanzen</span>
                          )}
                          {entry.actualDate && (
                            <span class="text-xs opacity-50">
                              (gesät {entry.actualDate})
                            </span>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </>
            )
          })}
        </div>
      </details>
    )}

    {/* Future weeks — hidden behind toggle */}
    {futureWeeks.length > 0 && (
      <details class="mt-4">
        <summary class="cursor-pointer text-sm font-medium opacity-60 hover:opacity-100">
          Weitere Wochen anzeigen ({futureWeeks.length})
        </summary>
        <div class="mt-2 space-y-1">
          {futureWeeks.map((kw, idx) => {
            const entries = calendarWeekMap.get(kw)!
            const month = kwToMonth(kw)
            const prevMonth = idx > 0 ? kwToMonth(futureWeeks[idx - 1]) : ''
            const showMonthHeader = month !== prevMonth
            return (
              <>
                {showMonthHeader && (
                  <div class="mt-4 mb-2 border-b pb-1">
                    <h3 class="text-base font-semibold opacity-70">{month}</h3>
                  </div>
                )}
                <div class="collapse collapse-arrow bg-base-200">
                  <input type="checkbox" />
                  <div class="collapse-title font-medium text-sm">
                    KW {kw}
                    <span class="ml-2 text-sm opacity-60">
                      ({entries.length} Einträge)
                    </span>
                  </div>
                  <div class="collapse-content">
                    <ul class="list-none space-y-1">
                      {sortByUrgency(entries).map((entry) => (
                        <li
                          class:list={[
                            'rounded px-2 py-1',
                            entry.status === 'done'
                              ? 'bg-success/10'
                              : urgencyColor(entry),
                          ]}
                        >
                          <div class="flex items-center gap-2">
                            {entry.status === 'done' && (
                              <span class="flex-shrink-0 text-success" title="Erledigt">&#10003;</span>
                            )}
                            <a
                              href={`./vegetables/${entry.id}`}
                              class:list={[
                                'link link-hover flex-shrink-0 font-medium',
                                entry.status === 'done' && 'line-through opacity-60',
                              ]}
                            >
                              {entry.name}
                            </a>
                            {entry.status !== 'done' && entry.type === 'sowing' && (
                              <span class="text-xs opacity-50">(noch bis KW {entry.lastPossibleWeek})</span>
                            )}
                          </div>
                          <div class="mt-1 flex flex-wrap gap-1">
                            {entry.type === 'plantOut' && (
                              <span class="badge badge-sm badge-primary">Pflanzen</span>
                            )}
                            {entry.succession > 1 && (
                              <span class="badge badge-sm badge-outline">
                                {entry.type === 'plantOut' ? `${entry.succession}. Pflanzung` : `${entry.succession}. Aussaat`}
                              </span>
                            )}
                            {entry.type === 'sowing' && entry.directSow && (
                              <span class="badge badge-sm badge-accent">Direktsaat</span>
                            )}
                            {entry.underCover && (
                              <span class="badge badge-sm badge-info">geschützt</span>
                            )}
                            {entry.overwintering && (
                              <span class="badge badge-sm badge-warning">Überwinterung</span>
                            )}
                            {entry.note && (
                              <span class="badge badge-sm badge-ghost">{entry.note}</span>
                            )}
                          </div>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </>
            )
          })}
        </div>
      </details>
    )}
  </div>
</Layout>

<style is:global>
  @media print {
    /* Hide site chrome */
    header, footer, nav, .navbar { display: none !important; }

    /* Print checklist layout */
    .print-grid {
      columns: 3;
      column-gap: 1.5rem;
    }
    .print-item {
      display: flex;
      align-items: baseline;
      gap: 0.3rem;
      break-inside: avoid;
      font-size: 0.75rem;
      line-height: 1.6;
    }
    .print-checkbox {
      width: 0.7rem;
      height: 0.7rem;
      flex-shrink: 0;
      appearance: none;
      border: 1.5px solid black;
      border-radius: 1px;
    }
    .print-note {
      font-size: 0.65rem;
      opacity: 0.7;
    }

    /* Section headers */
    .print-section {
      margin-bottom: 0.6rem;
    }
    .print-section-title {
      font-size: 0.7rem;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.2rem;
      border-bottom: 1.5px solid black;
      padding-bottom: 0.1rem;
    }

    /* Last-chance items: bold + red */
    .print-item-urgent {
      font-weight: bold;
      color: #c00;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }
    .print-item-urgent .print-note {
      font-weight: normal;
      color: #c00;
    }
    .print-checkbox-urgent {
      border: 2px solid #c00;
    }
    .print-section-title-urgent {
      color: #c00;
      border-bottom-color: #c00;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }
  }
</style>
